NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# App secret (sessions, cookies, etc.)
SECRET=change_me_in_production

# MongoDB
MONGO_URI=mongodb://localhost:27017/nexo

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookies
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# CORS
CORS_ORIGINS=http://localhost:3000
CORS_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_CREDENTIALS=true

# Frontend URL (used in verification/reset email links)
FRONTEND_URL=http://localhost:8000/api/auth

# SMTP (email delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=dummy_smtp_user
SMTP_PASS=dummy_smtp_password
SMTP_FROM=Nexo <no-reply@nexo.app>

# Storage (Cloudflare R2 / AWS S3)
# STORAGE_ENDPOINT is required for R2 and other S3-compatible providers; omit for AWS S3
STORAGE_ENDPOINT=https://dummy-endpoint.local
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=dummy_access_key
STORAGE_SECRET_KEY=dummy_secret_key
STORAGE_BUCKET=nexo-avatars
STORAGE_PUBLIC_URL=https://dummy-public-url.local

# Seed super admin (only used for npm run seed)
SEED_EMAIL=admin@nexo.app
SEED_PASSWORD=change_this_password
SEED_USERNAME=superadmin
